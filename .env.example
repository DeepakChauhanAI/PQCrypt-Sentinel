# ─── Core Application ──────────────────────────────────────────────────
# Environment: development | staging | production
APP_ENV=development
APP_NAME=PQCrypt Sentinel

# JWT signing secret — MUST be 32+ random bytes. NEVER commit a real value.
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated. Never use * in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

API_WORKERS=4
LOG_LEVEL=INFO

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pqcrypt:pqcrypt@localhost:5432/pqcrypt
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ─── Redis / Celery ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4

# ─── Scanner Tool Paths (inside the worker Docker container) ───────────
TSHARK_PATH=/usr/bin/tshark
NMAP_PATH=/usr/bin/nmap
OPENSSL_PATH=/usr/bin/openssl
PQSCAN_PATH=/usr/local/bin/pqcscan
TESTSSL_PATH=/usr/local/bin/testssl.sh
SSH_AUDIT_PATH=/usr/local/bin/ssh-audit

# ─── Scan Settings ─────────────────────────────────────────────────────
SCAN_THROTTLE_RATE=50
SCAN_TIMEOUT_SECONDS=10
SCAN_DEFAULT_PORTS=443,8443,22,636,993,995,8883
SCAN_RESULT_RETENTION_DAYS=730
SCAN_LOG_RETENTION_DAYS=90

# ─── Email / Notifications ─────────────────────────────────────────────
# SMTP is optional — notifications are silently skipped if not configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# Slack webhook for drift alerts — optional.
SLACK_WEBHOOK_URL=

# ─── Vault Integration (Phase 2) ───────────────────────────────────────
# Leave empty for MVP — connector credentials live in env vars or .env.
VAULT_URL=
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_PQC_PATH=secret/pqc

# ─── Air-Gap / Offline Mode ────────────────────────────────────────────
# When true, disables CT log polling, telemetry, and all external callbacks.
# Required for on-premise deployments with no internet access.
OFFLINE_MODE=false

# Allow scanning of local WiFi network (RFC1918 private subnets) and loopback systems (e.g. 127.0.0.1)
# Set to 1 to allow, 0 to block.
PQC_ALLOW_PRIVATE_RANGES=0
PQC_ALLOW_LOOPBACK=0

# Override only if you run a local CT log mirror.
CT_LOG_URL=https://crt.sh

# NEVER enable telemetry for a product sold to banks and regulated entities.
TELEMETRY_ENABLED=false

# ─── Quantum Timeline Configuration ───────────────────────────────────
# Year when quantum computers are expected to break RSA-2048.
# Used in Mosca's Theorem / HNDL exposure calculations.
# Default per NIST timeline: 2035 (RSA-2048 fully disallowed).
QUANTUM_TIMELINE_YEAR=2035

# ─── Risk Scoring Weights (optional override) ─────────────────────────
# Must sum to 100.0 or risk score calculation will fail.
RISK_WEIGHT_HNDL=30
RISK_WEIGHT_EXPOSURE=20
RISK_WEIGHT_CRITICALITY=20
RISK_WEIGHT_ALGORITHM=15
RISK_WEIGHT_DEADLINE=15

# ─── Development Only ─────────────────────────────────────────────────
# These are ignored in production. Do NOT ship with these set.
DEBUG=false
